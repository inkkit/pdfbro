# Folio Configuration
# Copy to .env and adjust as needed

# API Configuration
API_PORT=3000
CONCURRENCY=4
REQUEST_TIMEOUT=120s
LOG_LEVEL=info

# Chrome/LibreOffice Paths (optional, auto-detected if not set)
# CHROME_PATH=/usr/bin/google-chrome
# LIBREOFFICE_PATH=/usr/bin/soffice

# Chrome Flags
CHROME_NO_SANDBOX=false
CHROME_DISABLE_GPU=true

# Docker Registry (for publishing)
DOCKER_REGISTRY=ghcr.io
DOCKER_REPOSITORY=yourusername/folio
FOLIO_VERSION=latest
